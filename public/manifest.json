import SEO from "./SEO";
import { Link } from "react-router-dom";

export default function ArticleShell({
  title,
  description,
  path,
  seoMeta = {},
  structuredData = [],
  sidebarTerms = [],
  relatedTools = [],
  children,
}) {
  return (
    <div className="mx-auto max-w-4xl px-4 py-10 text-[#E0E0E0]">
      {/* SEO */}
      <SEO
        title={title}
        description={description}
        seoMeta={seoMeta}
        structuredData={structuredData}
      />

      {/* Title */}
      <h1 className="mb-6 text-3xl font-bold text-[#E0E0E0]">{title}</h1>

      <div className="grid grid-cols-1 gap-10 md:grid-cols-[1fr_250px]">
        {/* Main Content */}
        <article className="prose prose-invert max-w-none">
          {children}
        </article>

        {/* Sidebar */}
        <aside className="space-y-8">
          {/* Glossary Terms */}
          {sidebarTerms.length > 0 && (
            <div className="rounded-sm border border-[#A3FFD6]/20 bg-void/40 p-4">
              <p className="font-mono text-[10px] uppercase tracking-[0.2em] text-[#A3FFD6]">
                // Glossary Terms
              </p>
              <ul className="mt-2 list-disc pl-6 text-sm text-[#889988]">
                {sidebarTerms.map((term, i) => (
                  <li key={i}>
                    <Link
                      to={`/glossary#${term.slug}`}
                      className="text-[#A3FFD6] hover:underline"
                    >
                      {term.q}
                    </Link>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {/* Related Tools */}
          {relatedTools.length > 0 && (
            <div className="rounded-sm border border-[#A3FFD6]/20 bg-void/40 p-4">
              <p className="font-mono text-[10px] uppercase tracking-[0.2em] text-[#A3FFD6]">
                // Related Tools
              </p>
              <ul className="mt-2 list-disc pl-6 text-sm text-[#889988]">
                {relatedTools.map((tool, i) => (
                  <li key={i}>
                    <Link
                      to={tool.to}
                      className="text-[#A3FFD6] hover:underline"
                    >
                      {tool.label}
                    </Link>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </aside>
      </div>
    </div>
